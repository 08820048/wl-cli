{
  "name": "wl-cli",
  "description": "Welight CLI for WeChat article production",
  "version": "0.0.0",
  "author": "xuyi",
  "bin": {
    "wl": "./bin/run.js"
  },
  "bugs": "https://github.com/wl-cli/wl-cli/issues",
  "dependencies": {
    "@inquirer/prompts": "^8.4.1",
    "@mozilla/readability": "^0.6.0",
    "@oclif/core": "^4",
    "@oclif/plugin-help": "^6",
    "@oclif/plugin-plugins": "^5",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "front-matter": "^4.0.2",
    "jsdom": "^29.0.2",
    "juice": "^11.1.1",
    "marked": "^18.0.1",
    "ora": "^9.3.0",
    "reading-time": "^1.5.0",
    "terminal-link": "^5.0.0",
    "turndown": "^7.2.4",
    "undici": "^8.1.0"
  },
  "devDependencies": {
    "@eslint/compat": "^1",
    "@oclif/prettier-config": "^0.2.1",
    "@oclif/test": "^4",
    "@types/chai": "^4",
    "@types/fs-extra": "^11.0.4",
    "@types/jsdom": "^28.0.1",
    "@types/mocha": "^10",
    "@types/node": "^18",
    "@types/turndown": "^5.0.6",
    "chai": "^4",
    "eslint": "^9",
    "eslint-config-oclif": "^6",
    "eslint-config-prettier": "^10",
    "mocha": "^11",
    "oclif": "^4",
    "shx": "^0.3.3",
    "ts-node": "^10",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "./assets",
    "./bin",
    "./dist",
    "./oclif.manifest.json"
  ],
  "homepage": "https://github.com/wl-cli/wl-cli",
  "keywords": [
    "welight",
    "wechat",
    "markdown",
    "cli"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "type": "module",
  "oclif": {
    "bin": "wl",
    "dirname": "wl",
    "commands": "./dist/commands",
    "helpClass": "./dist/help.js",
    "plugins": [
      "@oclif/plugin-help",
      "@oclif/plugin-plugins"
    ],
    "theme": "./theme.json",
    "topicSeparator": " ",
    "topics": {
      "ai": {
        "description": "AI 创作与排版能力"
      },
      "article": {
        "description": "公众号文章工作流"
      },
      "copy": {
        "description": "复制公众号兼容内容到剪贴板"
      },
      "auth": {
        "description": "许可证登录与状态检查"
      },
      "publish": {
        "description": "发布到微信公众号"
      },
      "theme": {
        "description": "查看主题目录"
      }
    }
  },
  "repository": "wl-cli/wl-cli",
  "scripts": {
    "build": "shx rm -rf dist && tsc -b",
    "lint": "eslint",
    "postpack": "shx rm -f oclif.manifest.json",
    "posttest": "pnpm run lint",
    "prepack": "oclif manifest && oclif readme",
    "test": "mocha --forbid-only \"test/**/*.test.ts\"",
    "version": "oclif readme && git add README.md"
  },
  "types": "dist/index.d.ts"
}
